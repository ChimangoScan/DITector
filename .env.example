# Copie este arquivo para .env e preencha os valores.
# .env nunca é commitado (está no .gitignore).

# ── Papel deste nó ────────────────────────────────────────────────────────────
# primary   → roda MongoDB + Neo4j localmente + crawler
# secondary → crawler apenas; banco fica no nó primário
ROLE=primary

# ── Endereço do nó primário (obrigatório apenas se ROLE=secondary) ────────────
DB_HOST=

# ── Crawler ───────────────────────────────────────────────────────────────────
WORKERS=3
SHARD=0
SHARDS=1
ACCOUNTS=accounts.json
